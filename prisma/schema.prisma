generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── SAAS ────────────────────────────────────────────────
model Salon {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  phone       String
  whatsapp    String
  logoBase64  String?
  plan        String   @default("TRIAL") // TRIAL | ACTIVE | INACTIVE
  pixKey      String?
  createdAt   DateTime @default(now())

  users       User[]
  services    Service[]
  promotions  Promotion[]
}

// ─── AUTH ────────────────────────────────────────────────
model User {
  id           String        @id @default(cuid())
  salonId      String
  name         String
  phone        String
  email        String?
  passwordHash String
  role         String        @default("CLIENT") // SUPERADMIN | ADMIN | CLIENT
  createdAt    DateTime      @default(now())

  salon        Salon         @relation(fields: [salonId], references: [id], onDelete: Cascade)
  sessions     Session[]
  loyaltyCards LoyaltyCard[]

  @@unique([salonId, phone])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── SALON DATA ──────────────────────────────────────────
model Service {
  id             String         @id @default(cuid())
  salonId        String
  name           String
  type           String         // SERVICE | PRODUCT
  qrCode         String         @unique
  active         Boolean        @default(true)
  createdAt      DateTime       @default(now())
  salon          Salon          @relation(fields: [salonId], references: [id], onDelete: Cascade)
  loyaltyEntries LoyaltyEntry[]
}

model LoyaltyCard {
  id        String         @id @default(cuid())
  userId    String
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries   LoyaltyEntry[]
  rewards   Reward[]
}

model LoyaltyEntry {
  id            String      @id @default(cuid())
  loyaltyCardId String
  serviceId     String
  registeredAt  DateTime    @default(now())
  loyaltyCard   LoyaltyCard @relation(fields: [loyaltyCardId], references: [id], onDelete: Cascade)
  service       Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model Reward {
  id            String      @id @default(cuid())
  loyaltyCardId String
  type          String      // GIFT | DISCOUNT_50
  reason        String
  used          Boolean     @default(false)
  createdAt     DateTime    @default(now())
  loyaltyCard   LoyaltyCard @relation(fields: [loyaltyCardId], references: [id], onDelete: Cascade)
}

model Promotion {
  id          String   @id @default(cuid())
  salonId     String
  title       String
  description String
  active      Boolean  @default(true)
  startsAt    DateTime
  endsAt      DateTime
  createdAt   DateTime @default(now())
  salon       Salon    @relation(fields: [salonId], references: [id], onDelete: Cascade)
}

// ─── SUPERADMIN ──────────────────────────────────────────
model SuperAdmin {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
}
